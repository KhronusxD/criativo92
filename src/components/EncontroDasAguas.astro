---
const lines = [
  'Duas águas, uma corrente.',
  'A criatividade do Rio Negro.',
  'A estratégia do Solimões.',
  'Juntas, viram Criativo 92.',
];
---

<section class="enc" id="encontro" data-encontro>
  <div class="enc__stage">
    <!-- correntes: fotos reais dos dois rios deslizando pra se encontrar -->
    <div class="enc__waters" aria-hidden="true">
      <div class="corrente corrente--negro"><img src="/rio-negro.jpg" alt="" width="1600" height="900" /></div>
      <div class="corrente corrente--solimoes"><img src="/rio-solimoes.jpg" alt="" width="1600" height="900" /></div>
      <!-- linha de espuma / encontro -->
      <div class="enc__seam"></div>
    </div>

    <!-- texto -->
    <div class="enc__copy container">
      <p class="eyebrow enc__eyebrow">O nosso método</p>
      <h2 class="enc__title display">
        {lines.map((l) => (
          <span class="line-mask"><span class="encontro__line">{l}</span></span>
        ))}
      </h2>
    </div>
  </div>
</section>

<style>
  .enc { position: relative; }
  .enc__stage { position: relative; height: 100svh; overflow: hidden; display: flex; align-items: center; }
  .enc__waters { position: absolute; inset: 0; z-index: 0; background: var(--negro-900); }
  /* scrim p/ legibilidade do texto sobre a água */
  .enc__stage::after { content: ''; position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: linear-gradient(90deg, rgba(8,21,26,0.92) 0%, rgba(8,21,26,0.55) 36%, transparent 60%),
                linear-gradient(180deg, rgba(8,21,26,0.55), transparent 28%, transparent 72%, rgba(8,21,26,0.55)); }

  /* cada corrente = metade da tela; object-position recorta o padding (preto/branco)
     de cada foto pra fora, deixando só a metade com conteúdo de água. */
  .corrente { position: absolute; top: 0; bottom: 0; width: 50%; overflow: hidden; will-change: transform; }
  .corrente img { width: 100%; height: 100%; object-fit: cover; }
  .corrente--negro { left: 0; }
  .corrente--negro img { object-position: 0% 62%; }
  .corrente--solimoes { right: 0; }
  .corrente--solimoes img { object-position: 100% 62%; }

  /* espuma no encontro das águas */
  .enc__seam { position: absolute; left: 50%; top: 0; bottom: 0; width: 90px; transform: translateX(-50%); z-index: 1; pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(227,201,166,0.55), rgba(255,255,255,0.25), rgba(227,201,166,0.55), transparent);
    filter: blur(6px); mix-blend-mode: screen; opacity: 0.7; animation: seam-pulse 5s ease-in-out infinite; }
  @keyframes seam-pulse { 0%,100% { opacity: 0.5; transform: translateX(-50%) scaleY(1); } 50% { opacity: 0.85; transform: translateX(-50%) scaleY(1.02); } }

  .enc__copy { position: relative; z-index: 2; }
  .enc__eyebrow { color: var(--areia-300); }
  .enc__eyebrow::before { background: var(--areia-300); }
  .enc__title { margin-top: 1rem; text-shadow: 0 6px 40px rgba(0,0,0,0.65); }
  .line-mask { display: block; overflow: hidden; }
  .encontro__line { display: block; color: var(--claro); }
  .line-mask:last-child .encontro__line { color: var(--vitoria); }

  @media (prefers-reduced-motion: reduce) {
    .enc__seam { animation: none; }
    .corrente--negro, .corrente--solimoes { width: 50%; }
  }
</style>
