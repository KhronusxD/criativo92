---
const cases = [
  { nome: 'Tucumã Burger', cat: 'Branding + Social', res: '+312% em pedidos no iFood', c1: '#ff4d7e', c2: '#e6502b' },
  { nome: 'Cerâmica Marajó', cat: 'E-commerce + Tráfego', res: 'ROAS 7,4 em 90 dias', c1: '#c8884b', c2: '#9a6531' },
  { nome: 'Festival do Boi Digital', cat: 'Campanha 360°', res: '2,1M de alcance orgânico', c1: '#2e7d4f', c2: '#1f5c3d' },
  { nome: 'Guaraná da Terra', cat: 'Audiovisual + UGC', res: '18 criadores, 900k views', c1: '#ffc32b', c2: '#e6502b' },
  { nome: 'Pousada Encontro', cat: 'Site + SEO Local', res: '1º lugar no Google em Manaus', c1: '#2f8ae0', c2: '#1656b0' },
];
---

<section class="pf" id="portfolio">
  <div class="pf__wrap" data-hscroll>
    <div class="pf__inner hscroll__inner">
      <article class="pf__intro">
        <p class="eyebrow">Cases · feitos aqui</p>
        <h2 class="pf__title display">Quem<br />confia,<br /><span class="hand">cresce.</span></h2>
        <p class="lead">Arraste →</p>
      </article>

      {cases.map((c, i) => (
        <article class="pf__card" style={`--c1:${c.c1};--c2:${c.c2}`}>
          <span class="pf__num">{String(i + 1).padStart(2, '0')}</span>
          <div class="pf__art" aria-hidden="true"></div>
          <div class="pf__meta">
            <span class="pf__cat">{c.cat}</span>
            <h3 class="pf__name">{c.nome}</h3>
            <p class="pf__res">{c.res}</p>
          </div>
        </article>
      ))}

      <article class="pf__cta-card">
        <h3>Seu projeto<br />é o próximo.</h3>
        <a href="#contato" class="btn btn--primary" data-magnetic><span class="btn-glow"></span><span>Bora?</span></a>
      </article>
    </div>
  </div>
</section>

<style>
  .pf { background: var(--negro-900); }
  .pf__wrap { height: 100svh; overflow: hidden; }
  .pf__inner { display: flex; height: 100%; align-items: center; gap: 1.6rem; padding-inline: var(--gutter); width: max-content; }
  .pf__intro { flex: 0 0 auto; width: min(80vw, 30rem); padding-right: 2rem; }
  .pf__title { margin: 1rem 0; }

  .pf__card {
    flex: 0 0 auto; width: min(80vw, 30rem); height: 70vh; border-radius: var(--radius);
    background: linear-gradient(160deg, var(--c1), var(--c2)); color: var(--negro-900);
    padding: 2rem; position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: flex-end;
  }
  .pf__num { position: absolute; top: 1.4rem; left: 1.6rem; font-family: var(--font-display); font-weight: 900; font-size: 1.4rem; opacity: 0.6; }
  .pf__art { position: absolute; inset: 0; background:
      radial-gradient(circle at 80% 18%, rgba(255,255,255,0.35), transparent 40%),
      repeating-linear-gradient(45deg, rgba(0,0,0,0.06) 0 12px, transparent 12px 24px);
    mix-blend-mode: soft-light; }
  .pf__meta { position: relative; z-index: 1; }
  .pf__cat { font-weight: 700; font-size: 0.85rem; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.8; }
  .pf__name { font-size: clamp(1.8rem, 1.2rem + 2vw, 2.8rem); margin: 0.3rem 0 0.8rem; }
  .pf__res { font-weight: 700; font-size: 1.05rem; background: var(--negro-900); color: var(--areia-300); display: inline-block; padding: 0.4em 0.9em; border-radius: 999px; }

  .pf__cta-card {
    flex: 0 0 auto; width: min(70vw, 24rem); height: 70vh; border-radius: var(--radius);
    border: 1.5px dashed var(--linha); display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 1.5rem; padding: 2rem;
  }
  .pf__cta-card h3 { font-size: clamp(1.8rem, 1.4rem + 2vw, 3rem); }

  @media (max-width: 860px) {
    /* no mobile o pin pode pesar; vira scroll vertical simples */
    .pf__wrap { height: auto; }
    .pf__inner { flex-direction: column; width: 100%; height: auto; padding-block: 4rem; align-items: stretch; }
    .pf__intro, .pf__card, .pf__cta-card { width: 100%; }
    .pf__card { height: auto; min-height: 60vh; }
  }
</style>
