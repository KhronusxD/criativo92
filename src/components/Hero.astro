---
const title = ['Marketing', 'que', 'corre', 'como', 'rio.'];
---

<section class="hero" id="topo">
  <!-- fundo: encontro das águas animado -->
  <div class="hero__aura" aria-hidden="true">
    <div class="aura aura--negro"></div>
    <div class="aura aura--solimoes"></div>
    <div class="aura aura--vitoria"></div>
  </div>

  <!-- folhagem realista nas bordas (sway + parallax) -->
  <div class="leaf leaf--bl" data-parallax="0.18" aria-hidden="true"><img src="/folha-bananeira.png" alt="" /></div>
  <div class="leaf leaf--tr" data-parallax="0.14" aria-hidden="true"><img src="/folhas.png" alt="" /></div>

  <div class="hero__inner container">
    <p class="eyebrow" data-hero-fade>Agência criativa · Manaus — AM · DDD 92</p>

    <h1 class="hero__title display">
      {title.map((w) => (
        <span class="word-mask"><span class="word">{w}&nbsp;</span></span>
      ))}
    </h1>

    <p class="hero__lead lead" data-hero-fade>
      Nascemos na confluência do <strong>Rio Negro</strong> e do <strong>Solimões</strong> —
      onde criatividade e estratégia viram uma corrente só. Marca, conteúdo e mídia
      com sotaque amazônico e resultado de gente grande. <span class="hand">égua, que criativo!</span>
    </p>

    <div class="hero__cta" data-hero-fade>
      <a href="#contato" class="btn btn--primary" data-magnetic>
        <span class="btn-glow"></span>
        <span>Bora criar →</span>
      </a>
      <a href="#portfolio" class="btn btn--ghost">
        <span>Ver nossos cases</span>
      </a>
    </div>
  </div>

  <!-- boto mascote -->
  <div class="hero__boto" data-parallax="0.28">
    <img src="/boto.png" alt="Boto-cor-de-rosa, mascote da Criativo 92" class="hero__boto-img" width="820" height="820" />
  </div>

  <a href="#servicos" class="hero__scroll" aria-label="Rolar para baixo">
    <span></span>desça o rio
  </a>
</section>

<style>
  .hero {
    position: relative; min-height: 100svh; overflow: clip;
    display: flex; align-items: center;
    padding-block: 9rem 5rem;
  }

  /* ---- auras (encontro das águas) ---- */
  .hero__aura { position: absolute; inset: 0; z-index: -1; filter: blur(10px); }
  .aura { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.75; }
  .aura--negro { width: 65vw; height: 65vw; left: -15vw; top: -10vw; background: radial-gradient(circle, #14343d, transparent 70%); animation: drift1 22s ease-in-out infinite; }
  .aura--solimoes { width: 60vw; height: 60vw; right: -18vw; top: 10vw; background: radial-gradient(circle, #9a6531, transparent 68%); animation: drift2 26s ease-in-out infinite; }
  .aura--vitoria { width: 36vw; height: 36vw; left: 30vw; bottom: -16vw; background: radial-gradient(circle, rgba(255,77,126,0.5), transparent 70%); animation: drift1 19s ease-in-out infinite reverse; }
  @keyframes drift1 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(6vw,4vw) scale(1.1); } }
  @keyframes drift2 { 0%,100% { transform: translate(0,0) scale(1.05); } 50% { transform: translate(-5vw,6vw) scale(0.95); } }

  /* ---- folhagem realista ---- */
  .leaf { position: absolute; z-index: 0; pointer-events: none; }
  .leaf img { width: 100%; height: auto; display: block; transform-origin: center; will-change: transform; filter: drop-shadow(0 18px 24px rgba(0,0,0,0.35)); }
  .leaf--bl { bottom: -9%; left: -5%; width: clamp(170px, 22vw, 360px); }
  .leaf--bl img { animation: leaf-sway-b 9.5s ease-in-out infinite; }
  .leaf--tr { top: -2%; right: -3%; width: clamp(150px, 18vw, 300px); }
  .leaf--tr img { animation: leaf-sway-180 8s ease-in-out infinite; }
  @keyframes leaf-sway-b { 0%,100% { transform: rotate(3deg); } 50% { transform: rotate(-3deg); } }
  /* folhas.png rotacionada 180° + sway */
  @keyframes leaf-sway-180 { 0%,100% { transform: rotate(176deg); } 50% { transform: rotate(184deg); } }
  @media (prefers-reduced-motion: reduce) { .leaf img { animation: none; } }

  /* ---- conteúdo ---- */
  .hero__inner { position: relative; z-index: 2; max-width: 60rem; }
  .hero__title { margin: 1.4rem 0 1.6rem; }
  .word-mask { display: inline-block; overflow: hidden; vertical-align: top; }
  .word { display: inline-block; }
  .hero__title .word-mask:last-child .word { color: var(--vitoria); }
  .hero__lead { margin-bottom: 2.2rem; }
  .hero__lead strong { color: var(--areia-300); font-weight: 700; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 1rem; }

  /* ---- boto ---- */
  .hero__boto { position: absolute; z-index: 1; right: clamp(-2rem, 2vw, 4rem); top: 14%; width: clamp(240px, 34vw, 520px); }
  .hero__boto-img { width: 100%; height: auto; filter: drop-shadow(0 30px 50px rgba(0,0,0,0.45)); animation: boto-bob 6.5s ease-in-out infinite; will-change: transform; }
  @keyframes boto-bob { 0%,100% { transform: translateY(0) rotate(-2deg); } 50% { transform: translateY(-18px) rotate(1deg); } }
  @media (prefers-reduced-motion: reduce) { .hero__boto-img { animation: none; } }

  /* ---- scroll cue ---- */
  .hero__scroll {
    position: absolute; left: var(--gutter); bottom: 2rem; z-index: 2;
    display: inline-flex; align-items: center; gap: 0.7rem;
    font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--claro-dim);
  }
  .hero__scroll span { width: 30px; height: 46px; border: 1.5px solid var(--linha); border-radius: 999px; position: relative; }
  .hero__scroll span::after { content: ''; position: absolute; left: 50%; top: 8px; width: 4px; height: 8px; margin-left: -2px; background: var(--vitoria); border-radius: 2px; animation: scroll-cue 1.8s ease-in-out infinite; }
  @keyframes scroll-cue { 0% { transform: translateY(0); opacity: 1; } 70% { transform: translateY(16px); opacity: 0; } 100% { opacity: 0; } }

  @media (max-width: 860px) {
    .hero__boto { position: relative; right: auto; top: auto; width: min(70vw, 320px); margin: 2.5rem auto 0; }
    .hero { min-height: auto; }
    .hero__scroll { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .aura { animation: none; }
    .hero__scroll span::after { animation: none; }
  }
</style>
