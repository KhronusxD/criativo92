---
import Marajoara from './illustrations/Marajoara.astro';

const servicos = [
  { tag: '01', titulo: 'Branding & Identidade', desc: 'Marcas com raiz e alma. Naming, logo, paleta e verbal que parecem ter nascido daqui — porque nasceram.', cor: 'var(--vitoria)' },
  { tag: '02', titulo: 'Social Media', desc: 'Conteúdo que conversa no idioma da sua audiência. Linha editorial, design e copy que dão o que falar.', cor: 'var(--arara)' },
  { tag: '03', titulo: 'Tráfego Pago', desc: 'Meta e Google Ads com cabeça de dado e mão de criativo. Verba que vira cliente, não só impressão.', cor: 'var(--floresta-500)' },
  { tag: '04', titulo: 'Audiovisual & UGC', desc: 'Vídeo que segura o dedo. Roteiro, captação e edição com a estética da floresta e ritmo de internet.', cor: 'var(--solimoes-500)' },
  { tag: '05', titulo: 'Sites & Landing Pages', desc: 'Páginas rápidas, bonitas e que convertem. Motion premium e SEO pra você ser achado e lembrado.', cor: 'var(--vitoria)' },
  { tag: '06', titulo: 'Estratégia & Consultoria', desc: 'Diagnóstico, posicionamento e plano. A bússola antes do remo — pra remar pro lugar certo.', cor: 'var(--arara)' },
];
---

<section class="srv section" id="servicos">
  <div class="srv__mara"><Marajoara count={12} /></div>

  <div class="container">
    <header class="srv__head">
      <p class="eyebrow" data-reveal>O que a gente faz</p>
      <h2 class="srv__title display" data-reveal>Tudo que sua<br />marca precisa<span class="hand"> — e mais</span></h2>
    </header>

    <ul class="srv__grid">
      {servicos.map((s) => (
        <li class="srv__card" data-reveal data-tilt>
          <span class="srv__tag" style={`--c:${s.cor}`}>{s.tag}</span>
          <h3 class="srv__card-title">{s.titulo}</h3>
          <p class="srv__card-desc">{s.desc}</p>
          <span class="srv__arrow" style={`--c:${s.cor}`} aria-hidden="true">→</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .srv { background: var(--negro-800); }
  .srv__mara { max-width: 1100px; margin: 0 auto clamp(3rem, 8vw, 6rem); padding-inline: var(--gutter); opacity: 0.8; }
  .srv__head { margin-bottom: clamp(2.5rem, 6vw, 4rem); }
  .srv__title { margin-top: 1rem; }
  .srv__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  .srv__card {
    position: relative; padding: clamp(1.6rem, 3vw, 2.2rem); border-radius: var(--radius);
    background: linear-gradient(165deg, var(--negro-700), var(--negro-800));
    border: 1px solid var(--linha);
    transform-style: preserve-3d; will-change: transform;
    transition: border-color 0.4s, box-shadow 0.4s;
    overflow: hidden;
  }
  .srv__card::before {
    content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1px;
    background: linear-gradient(165deg, var(--c, var(--vitoria)), transparent 55%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    opacity: 0; transition: opacity 0.4s;
  }
  .srv__card:hover { border-color: transparent; box-shadow: 0 24px 60px -30px rgba(0,0,0,0.7); }
  .srv__card:hover::before { opacity: 1; }
  .srv__tag { display: inline-block; font-family: var(--font-display); font-weight: 900; font-size: 1.1rem; color: var(--c, var(--vitoria)); margin-bottom: 1.4rem; }
  .srv__card-title { font-size: clamp(1.2rem, 1rem + 0.8vw, 1.6rem); margin-bottom: 0.7rem; }
  .srv__card-desc { color: var(--claro-dim); font-size: 0.98rem; }
  .srv__arrow { position: absolute; top: clamp(1.6rem, 3vw, 2.2rem); right: clamp(1.6rem, 3vw, 2.2rem); color: var(--c); font-size: 1.4rem; opacity: 0; transform: translateX(-8px); transition: opacity 0.4s, transform 0.4s var(--ease-out); }
  .srv__card:hover .srv__arrow { opacity: 1; transform: translateX(0); }

  @media (max-width: 940px) { .srv__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .srv__grid { grid-template-columns: 1fr; } }
</style>
