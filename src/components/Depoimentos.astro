---
const deps = [
  { txt: 'A Criativo 92 entendeu a nossa marca melhor do que a gente. O resultado apareceu no caixa já no segundo mês.', nome: 'Marina Cordeiro', cargo: 'Sócia · Tucumã Burger', ini: 'MC' },
  { txt: 'Não é agência de slide bonito. É gente que rema junto e cobra resultado. Virou parte do nosso time.', nome: 'Jonas Albuquerque', cargo: 'CEO · Cerâmica Marajó', ini: 'JA' },
  { txt: 'Conteúdo com a nossa cara, com o nosso sotaque. Manaus se reconheceu na campanha e comprou a ideia.', nome: 'Priscila Tapajós', cargo: 'Mkt · Guaraná da Terra', ini: 'PT' },
];
---

<section class="dep section">
  <div class="container">
    <header class="dep__head">
      <p class="eyebrow" data-reveal>Quem rema com a gente</p>
      <h2 class="dep__title display" data-reveal>Orgulho de<br />quem confia</h2>
    </header>

    <ul class="dep__grid">
      {deps.map((d) => (
        <li class="dep__card" data-reveal data-tilt>
          <p class="dep__quote">“{d.txt}”</p>
          <div class="dep__who">
            <span class="dep__avatar" aria-hidden="true">{d.ini}</span>
            <span class="dep__id">
              <strong>{d.nome}</strong>
              <small>{d.cargo}</small>
            </span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .dep { background: var(--negro-800); }
  .dep__head { margin-bottom: clamp(2.5rem, 6vw, 4rem); }
  .dep__title { margin-top: 1rem; }
  .dep__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  .dep__card {
    padding: clamp(1.6rem, 3vw, 2.2rem); border-radius: var(--radius);
    background: linear-gradient(165deg, var(--negro-700), var(--negro-800));
    border: 1px solid var(--linha); display: flex; flex-direction: column; gap: 1.6rem; justify-content: space-between;
    will-change: transform;
  }
  .dep__quote { font-size: 1.1rem; line-height: 1.5; color: var(--claro); }
  .dep__who { display: flex; align-items: center; gap: 0.9rem; }
  .dep__avatar { width: 46px; height: 46px; border-radius: 50%; display: grid; place-items: center; font-family: var(--font-display); font-weight: 900; color: var(--negro-900); background: var(--solimoes-500); flex: 0 0 auto; }
  .dep__id { display: flex; flex-direction: column; }
  .dep__id strong { font-weight: 700; }
  .dep__id small { color: var(--claro-dim); }

  @media (max-width: 940px) { .dep__grid { grid-template-columns: 1fr; max-width: 32rem; } }
</style>
