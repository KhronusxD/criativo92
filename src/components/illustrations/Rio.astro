---
/* Rio — faixa de ondas com rolagem horizontal infinita (2 camadas, velocidades
   diferentes). Cada camada tem o path duplicado lado a lado pro loop ser contínuo. */
interface Props { class?: string }
const { class: className = '' } = Astro.props;

/* onda tileável de 600px de largura; duplicada => 1200 */
const wave = 'M0 60 C 100 20 200 100 300 60 C 400 20 500 100 600 60 L600 160 L0 160 Z';
---

<svg class:list={['rio', className]} viewBox="0 0 1200 160" fill="none" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="rioBack" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#163339" />
      <stop offset="1" stop-color="#0b1a1f" />
    </linearGradient>
    <linearGradient id="rioFront" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#1f5c3d" />
      <stop offset="1" stop-color="#10262b" />
    </linearGradient>
  </defs>

  <g class="rio__layer rio__back">
    <path d={wave} fill="url(#rioBack)" />
    <path d={wave} transform="translate(600 0)" fill="url(#rioBack)" />
  </g>
  <g class="rio__layer rio__front" transform="translate(0 24)">
    <path d={wave} fill="url(#rioFront)" />
    <path d={wave} transform="translate(600 0)" fill="url(#rioFront)" />
  </g>
</svg>

<style>
  .rio { width: 100%; height: auto; display: block; }
  .rio__back { animation: rio-flow 18s linear infinite; }
  .rio__front { animation: rio-flow 11s linear infinite; }
  @keyframes rio-flow { from { transform: translateX(0); } to { transform: translateX(-600px); } }
  /* o front tem translate(0 24) próprio; combinamos via wrapper de animação */
  .rio__front { animation-name: rio-flow-front; }
  @keyframes rio-flow-front { from { transform: translate(0, 24px); } to { transform: translate(-600px, 24px); } }
  @media (prefers-reduced-motion: reduce) { .rio__layer { animation: none; } }
</style>
