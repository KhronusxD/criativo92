---
/* Cluster de folhas (samaúma / bananeira) — sway de vento em loop, delays variados.
   Posição fica no grupo externo (atributo transform); o sway anima o grupo interno
   via CSS, pra não haver conflito entre transform de atributo e de CSS. */
interface Props { class?: string }
const { class: className = '' } = Astro.props;

const veins = (n: number) => Array.from({ length: n });
---

<svg class:list={['folhas', className]} viewBox="0 0 300 360" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="leafG" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#2e7d4f" />
      <stop offset="1" stop-color="#15462e" />
    </linearGradient>
  </defs>

  <g>
    <g class="folha" style="--d:0s">
      <path d="M150 350 C 90 300 70 200 150 70 C 230 200 210 300 150 350 Z" fill="url(#leafG)" />
      <path d="M150 350 L150 90" stroke="#0c3a25" stroke-width="3" opacity="0.6" />
      {veins(6).map((_, i) => (<path d={`M150 ${130 + i * 36} L${110 - i * 4} ${110 + i * 36}`} stroke="#0c3a25" stroke-width="1.6" opacity="0.5" />))}
      {veins(6).map((_, i) => (<path d={`M150 ${130 + i * 36} L${190 + i * 4} ${110 + i * 36}`} stroke="#0c3a25" stroke-width="1.6" opacity="0.5" />))}
    </g>
  </g>

  <g transform="translate(70 60) rotate(-26) scale(0.7)">
    <g class="folha" style="--d:.6s">
      <path d="M150 350 C 90 300 70 200 150 70 C 230 200 210 300 150 350 Z" fill="#256b43" />
      <path d="M150 350 L150 90" stroke="#0c3a25" stroke-width="3" opacity="0.5" />
    </g>
  </g>

  <g transform="translate(150 80) rotate(28) scale(0.62)">
    <g class="folha" style="--d:1.1s">
      <path d="M150 350 C 90 300 70 200 150 70 C 230 200 210 300 150 350 Z" fill="#1f5c3d" />
      <path d="M150 350 L150 90" stroke="#0c3a25" stroke-width="3" opacity="0.5" />
    </g>
  </g>
</svg>

<style>
  .folhas { width: 100%; height: auto; overflow: visible; }
  .folha { transform-box: fill-box; transform-origin: bottom center; animation: leaf-sway 7s ease-in-out infinite; animation-delay: var(--d); }
  @keyframes leaf-sway { 0%, 100% { transform: rotate(-3deg); } 50% { transform: rotate(3deg); } }
  @media (prefers-reduced-motion: reduce) { .folha { animation: none; } }
</style>
