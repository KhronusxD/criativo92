---
/* Boto-cor-de-rosa — mascote. Flutua (idle), pisca, solta bolhas, faz parallax. */
interface Props { class?: string }
const { class: className = '' } = Astro.props;
---

<svg
  class:list={['boto', className]}
  viewBox="0 0 440 320"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Ilustração de um boto-cor-de-rosa"
>
  <defs>
    <linearGradient id="botoBody" x1="60" y1="80" x2="380" y2="260" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#ff8fb4" />
      <stop offset="0.55" stop-color="#ff5c8a" />
      <stop offset="1" stop-color="#e23e76" />
    </linearGradient>
    <linearGradient id="botoBelly" x1="120" y1="200" x2="300" y2="280" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#ffd0df" />
      <stop offset="1" stop-color="#ffb0cb" />
    </linearGradient>
  </defs>

  <!-- bolhas do respiradouro -->
  <g class="boto__bubbles" fill="#bfe9f2" opacity="0.85">
    <circle cx="150" cy="70" r="6" />
    <circle cx="135" cy="48" r="4" />
    <circle cx="158" cy="30" r="3" />
  </g>

  <g class="boto__body">
    <!-- cauda -->
    <path class="boto__tail" d="M352 150c28-26 60-30 84-44-6 26-2 44 8 64-30-6-58-2-86-2z" fill="url(#botoBody)" />
    <!-- corpo -->
    <path d="M70 168c-6-46 34-86 96-92 70-7 132 18 178 64 14 14 18 30 6 40-20 16-58 22-104 24-78 4-170-2-176-36z" fill="url(#botoBody)" />
    <!-- barriga clara -->
    <path d="M120 196c44 22 132 26 188 10-22 18-66 28-118 26-40-2-62-14-70-36z" fill="#ffc3d8" opacity="0.65" />
    <!-- nadadeira peitoral -->
    <path d="M176 196c-10 28-8 50 4 70-26-10-44-34-46-64z" fill="#e23e76" />
    <!-- crista dorsal (botos têm crista, não barbatana alta) -->
    <path d="M210 84c20-4 40 0 56 8-18 2-38 6-58 12z" fill="#ff7aa6" />
    <!-- bico / rostro -->
    <path d="M70 168c-22 6-44 6-64 18 16 6 26 16 30 30 18-14 36-22 52-30z" fill="url(#botoBody)" />
    <!-- olho -->
    <g class="boto__eye">
      <circle cx="120" cy="150" r="9" fill="#2a0d18" />
      <circle cx="123" cy="147" r="3" fill="#fff" />
    </g>
    <!-- sorriso -->
    <path d="M58 192c14 6 30 8 46 4" stroke="#a82a55" stroke-width="3" stroke-linecap="round" />
  </g>
</svg>

<style>
  .boto { width: 100%; height: auto; overflow: visible; }
  .boto__body { transform-box: fill-box; transform-origin: center; animation: boto-float 5.5s var(--ease-soft, ease-in-out) infinite; }
  .boto__tail { transform-box: fill-box; transform-origin: left center; animation: boto-tail 3.4s ease-in-out infinite; }
  .boto__eye { animation: boto-blink 5.2s steps(1) infinite; transform-box: fill-box; transform-origin: center; }
  .boto__bubbles circle { animation: boto-bubble 4s ease-in infinite; transform-box: fill-box; transform-origin: center; }
  .boto__bubbles circle:nth-child(2) { animation-delay: 0.7s; }
  .boto__bubbles circle:nth-child(3) { animation-delay: 1.4s; }

  @keyframes boto-float { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-14px) rotate(-1.5deg); } }
  @keyframes boto-tail { 0%,100% { transform: rotate(0deg); } 50% { transform: rotate(-9deg); } }
  @keyframes boto-blink { 0%,92%,100% { transform: scaleY(1); } 96% { transform: scaleY(0.1); } }
  @keyframes boto-bubble { 0% { transform: translateY(0) scale(0.6); opacity: 0; } 30% { opacity: 0.85; } 100% { transform: translateY(-40px) scale(1); opacity: 0; } }

  @media (prefers-reduced-motion: reduce) {
    .boto__body, .boto__tail, .boto__eye, .boto__bubbles circle { animation: none; }
  }
</style>
