---
/* Grafismo geométrico inspirado na cerâmica marajoara. Traços usam pathLength=1
   pra "desenhar" (stroke-dashoffset) quando ganham a classe .drawn (via scroll). */
interface Props { class?: string; count?: number }
const { class: className = '', count = 10 } = Astro.props;
const glyphs = Array.from({ length: count });
---

<svg class:list={['mara', className]} viewBox="0 0 1200 90" fill="none" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  {glyphs.map((_, i) => (
    <g transform={`translate(${i * 120} 0) ${i % 2 ? 'scale(1 -1) translate(0 -90)' : ''}`}>
      <path class="mara__l" pathLength="1" d="M16 70 L16 22 L70 22 L70 64 L36 64 L36 40 L58 40 L58 54" stroke="currentColor" stroke-width="3.5" stroke-linecap="square" stroke-linejoin="miter" />
      <circle class="mara__d" cx="92" cy="34" r="6" fill="currentColor" />
      <path class="mara__l" pathLength="1" d="M88 58 L112 58 M100 50 L100 70" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
    </g>
  ))}
</svg>

<style>
  .mara { width: 100%; height: auto; color: var(--solimoes-500); }
  .mara__l { stroke-dasharray: 1; stroke-dashoffset: 1; transition: stroke-dashoffset 1.1s var(--ease-out, ease); }
  .mara.drawn .mara__l { stroke-dashoffset: 0; }
  .mara__d { transform-box: fill-box; transform-origin: center; opacity: 0; transition: opacity .6s ease .4s; }
  .mara.drawn .mara__d { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .mara__l { stroke-dashoffset: 0; transition: none; }
    .mara__d { opacity: 1; transition: none; }
  }
</style>
