---
/* Peixe-boi — nada lento, cauda ondula. Atravessa faixas via motion path. */
interface Props { class?: string }
const { class: className = '' } = Astro.props;
---

<svg class:list={['pboi', className]} viewBox="0 0 380 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Peixe-boi da Amazônia">
  <defs>
    <linearGradient id="pboiG" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#7d8a8f" />
      <stop offset="1" stop-color="#566064" />
    </linearGradient>
  </defs>
  <g class="pboi__swim">
    <!-- cauda em pá -->
    <path class="pboi__tail" d="M300 100 C 340 70 360 78 372 92 C 360 100 360 100 372 108 C 360 122 340 130 300 100 Z" fill="url(#pboiG)" />
    <!-- corpo -->
    <path d="M40 100 C 40 56 100 40 180 44 C 270 48 320 70 320 100 C 320 130 270 152 180 156 C 100 160 40 144 40 100 Z" fill="url(#pboiG)" />
    <!-- barriga clara -->
    <path d="M80 124 C 150 150 250 148 300 116 C 270 140 200 150 150 146 C 116 142 92 136 80 124 Z" fill="#9aa6aa" opacity="0.6" />
    <!-- nadadeira -->
    <path class="pboi__flipper" d="M120 130 C 116 156 126 174 146 184 C 134 158 138 142 150 132 Z" fill="#4c565a" />
    <!-- focinho + olho -->
    <circle cx="64" cy="92" r="5" fill="#20282b" />
    <path d="M44 104 q 8 10 22 10" stroke="#3a4448" stroke-width="3" fill="none" stroke-linecap="round" />
    <!-- vibrissas (bigodes) -->
    <path d="M44 100 l -16 -4 M46 108 l -16 2 M50 114 l -14 8" stroke="#3a4448" stroke-width="1.6" stroke-linecap="round" />
  </g>
</svg>

<style>
  .pboi { width: 100%; height: auto; overflow: visible; }
  .pboi__swim { transform-box: fill-box; transform-origin: center; animation: pboi-swim 6s ease-in-out infinite; }
  .pboi__tail { transform-box: fill-box; transform-origin: left center; animation: pboi-tail 3s ease-in-out infinite; }
  .pboi__flipper { transform-box: fill-box; transform-origin: top center; animation: pboi-fin 4s ease-in-out infinite; }
  @keyframes pboi-swim { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(8px) rotate(1.5deg); } }
  @keyframes pboi-tail { 0%,100% { transform: rotate(0deg); } 50% { transform: rotate(8deg); } }
  @keyframes pboi-fin { 0%,100% { transform: rotate(0deg); } 50% { transform: rotate(-10deg); } }
  @media (prefers-reduced-motion: reduce) { .pboi__swim, .pboi__tail, .pboi__flipper { animation: none; } }
</style>
