        <ul class="faq__list">
          {faqs.map((f, i) => (
            <li class="faq__item" data-reveal data-reveal-delay={String((i % 3) + 1)}>
              <button class="faq__q" type="button" data-faq-q aria-expanded="false">
                <span>{f.q}</span>
                <svg class="faq__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path class="faq__ico-v" d="M12 5v14"/></svg>
