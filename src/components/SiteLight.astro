    <!-- ============ BLOG ============ -->
    <section class="section panel-paper" id="blog">
      <div class="container">
        <header class="sec-head">
          <div data-reveal>
            <span class="eyebrow">Blog</span>
            <h2 class="h2">Ideias que fazem a marca crescer.</h2>
          </div>
          <p class="lead" data-reveal data-reveal-delay="1">Conteúdo prático sobre marketing, marca e vendas para o comércio da Amazônia.</p>
        </header>
        <ul class="posts">
          {posts.map((p, i) => (
            <li class="pcard" data-reveal data-reveal-delay={String((i % 3) + 1)}>
              <a href={`/blog/${p.slug}`}>
                <div class="pcard__img"><img src={p.cover} alt={p.title} loading="lazy" /></div>
