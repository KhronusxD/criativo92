        <p>Marketing e estratégia com método.<br />Manaus, Amazonas.</p>
      </div>
      <nav class="ft__col" aria-label="Páginas">
        <span class="ft__h">Navegar</span>
        {nav.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
      <nav class="ft__col" aria-label="Redes">
        <span class="ft__h">Redes</span>
        <a href="#">Instagram</a><a href="#">LinkedIn</a><a href="#">Behance</a>
      </nav>
      <div class="ft__col">
        <span class="ft__h">Contato</span>
        <a href="https://wa.me/5592981074692">(92) 98107-4692</a>
        <a href="mailto:contato@criativo92.com.br">contato@criativo92.com.br</a>
        <span class="ft__addr">Av. Djalma Batista, 2056 - Chapada, Sala 70<br />Manaus - AM, 69055-038</span>
      </div>
    </div>
    <div class="container ft__base">
      <span>© 2026 Criativo 92. Todos os direitos reservados.</span>
      <span>CNPJ 55.877.604/0001-02</span>
    </div>
  </footer>

  {diagnostico && (
    <div class="diag" data-diag-modal data-wa={waLink} data-diag={JSON.stringify(diagnostico)} aria-hidden="true">
      <div class="diag__backdrop" data-diag-close></div>
      <div class="diag__panel" role="dialog" aria-modal="true" aria-label={diagnostico.titulo}>
        <button class="diag__x" type="button" data-diag-close aria-label="Fechar diagnóstico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
        <div class="diag__bar"><span data-diag-bar></span></div>
        <div class="diag__body" data-diag-body></div>
      </div>
    </div>
  )}

  <script>
    // Header: fundo em vidro escuro só depois de rolar
    (function () {
      const hd = document.querySelector('.hd');
      if (!hd) return;
      const onScroll = () => hd.classList.toggle('is-stuck', window.scrollY > 8);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // menu mobile (hambúrguer)
      const burger = hd.querySelector('[data-menu-toggle]');
      if (burger) {
        const setOpen = (open) => { hd.classList.toggle('menu-open', open); burger.setAttribute('aria-expanded', String(open)); burger.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu'); };
        burger.addEventListener('click', () => setOpen(!hd.classList.contains('menu-open')));
        hd.querySelectorAll('[data-menu-link]').forEach((a) => a.addEventListener('click', () => setOpen(false)));
      }
    })();

    // Método: caixa que explica cada etapa, rotação automática + clique
    (function () {
      const steps = Array.from(document.querySelectorAll('[data-metodo-step]'));
      const panels = Array.from(document.querySelectorAll('[data-feat-panel]'));
      const btns = Array.from(document.querySelectorAll('[data-step-btn]'));
      if (steps.length === 0 || panels.length === 0) return;
      const N = panels.length;
      const INTERVAL = 6000;
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let cur = 0;
      let timer = null;

      function show(i) {
        cur = (i + N) % N;
        steps.forEach((s, idx) => s.classList.toggle('is-active', idx === cur));
        panels.forEach((p, idx) => p.setAttribute('data-active', idx === cur ? 'true' : 'false'));
        const bar = steps[cur].querySelector('.step__bar');
        if (bar) { bar.style.animation = 'none'; void bar.offsetWidth; bar.style.setProperty('--dur', INTERVAL / 1000 + 's'); bar.style.animation = ''; }
      }
      function start() { if (reduce) return; clearInterval(timer); timer = setInterval(() => show(cur + 1), INTERVAL); }
      function stop() { clearInterval(timer); }

      btns.forEach((b, idx) => b.addEventListener('click', () => { show(idx); start(); }));
      const feat = document.querySelector('[data-metodo-feature]');
      [feat, ...steps].forEach((el) => { if (!el) return; el.addEventListener('mouseenter', stop); el.addEventListener('mouseleave', start); });

      show(0);
      start();
    })();

    // Depoimentos: carrossel arrastável
    (function () {
      const car = document.querySelector('[data-deps-carousel]');
      if (!car) return;
      let down = false, startX = 0, startScroll = 0, moved = false;
      car.addEventListener('pointerdown', (e) => {
        down = true; moved = false; startX = e.clientX; startScroll = car.scrollLeft;
        car.classList.add('is-dragging');
        /* sem setPointerCapture: capturaria o ponteiro e mataria o clique nos botões internos */
      });
      car.addEventListener('pointermove', (e) => {
        if (!down) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        car.scrollLeft = startScroll - dx;
      });
      const end = () => { down = false; car.classList.remove('is-dragging'); };
      car.addEventListener('pointerup', end);
      car.addEventListener('pointercancel', end);
      car.addEventListener('pointerleave', end);
      // impede que o arraste dispare clique em links dentro dos cards
      car.addEventListener('click', (e) => { if (moved) { e.preventDefault(); e.stopPropagation(); } }, true);
      const amount = () => Math.min(car.clientWidth * 0.85, 380);
      const prev = document.querySelector('[data-deps-prev]');
      const next = document.querySelector('[data-deps-next]');
      if (prev) prev.addEventListener('click', () => car.scrollBy({ left: -amount(), behavior: 'smooth' }));
      if (next) next.addEventListener('click', () => car.scrollBy({ left: amount(), behavior: 'smooth' }));
    })();

    // Vídeos: carrossel arrastável
    (function () {
      const car = document.querySelector('[data-videos-carousel]');
      if (!car) return;
      let down = false, startX = 0, startScroll = 0, moved = false;
      car.addEventListener('pointerdown', (e) => {
        down = true; moved = false; startX = e.clientX; startScroll = car.scrollLeft;
        car.classList.add('is-dragging');
        /* sem setPointerCapture: capturaria o ponteiro e mataria o clique nos botões internos */
      });
      car.addEventListener('pointermove', (e) => {
        if (!down) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        car.scrollLeft = startScroll - dx;
      });
      const end = () => { down = false; car.classList.remove('is-dragging'); };
      car.addEventListener('pointerup', end);
      car.addEventListener('pointercancel', end);
      car.addEventListener('pointerleave', end);
      car.addEventListener('click', (e) => { if (moved) { e.preventDefault(); e.stopPropagation(); } }, true);
      const amount = () => Math.min(car.clientWidth * 0.8, 260);
      const prev = document.querySelector('[data-videos-prev]');
      const next = document.querySelector('[data-videos-next]');
      if (prev) prev.addEventListener('click', () => car.scrollBy({ left: -amount(), behavior: 'smooth' }));
      if (next) next.addEventListener('click', () => car.scrollBy({ left: amount(), behavior: 'smooth' }));
    })();

    // Vídeos: play ao clicar no botão
    (function () {
      document.querySelectorAll('[data-video-play]').forEach((btn) => {
        btn.addEventListener('pointerdown', (e) => e.stopPropagation());
        btn.addEventListener('click', () => {
          const frame = btn.closest('.videocard__frame');
          if (!frame) return;
          const vid = frame.querySelector('video');
          if (!vid) return;
          vid.setAttribute('controls', '');
          frame.classList.add('is-playing');
          btn.style.display = 'none';
          const p = vid.play();
          if (p && p.catch) p.catch(() => {});
        });
      });
    })();

    // FAQ acordeão
    (function () {
      document.querySelectorAll('[data-faq-q]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq__item');
          const ans = item.querySelector('.faq__a');
          const open = item.classList.toggle('is-open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          ans.style.maxHeight = open ? ans.scrollHeight + 'px' : '0';
        });
      });
    })();

    // Diagnóstico personalizado (quiz que qualifica o lead -> WhatsApp)
    (function () {
      const modal = document.querySelector('[data-diag-modal]');
      if (!modal) return;
      const cfg = JSON.parse(modal.getAttribute('data-diag') || '{}');
      const wa = modal.getAttribute('data-wa');
      const body = modal.querySelector('[data-diag-body]');
      const bar = modal.querySelector('[data-diag-bar]');
      const perguntas = cfg.perguntas || [];
      const totalSteps = perguntas.length + 2; // intro + perguntas + resultado (nome embutido no fim)
      const answers = new Array(perguntas.length).fill(null);
      let nome = '';
      let step = 0; // 0 = intro, 1..N = perguntas, N+1 = nome, N+2 = resultado

      const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

      function setProgress() {
        const done = Math.min(step, perguntas.length + 1);
        bar.style.width = Math.round((done / (perguntas.length + 1)) * 100) + '%';
      }

      function render() {
        setProgress();
        if (step === 0) {
          body.innerHTML =
            '<span class="diag__eyebrow">' + esc(cfg.titulo || 'Diagnóstico gratuito') + '</span>' +
            '<h3 class="diag__title">Vamos entender seu momento</h3>' +
            '<p class="diag__lead">' + esc(cfg.intro || '') + '</p>' +
            '<button class="btn btn--primary diag__next" data-start>Começar diagnóstico →</button>' +
            '<p class="diag__mini">Leva menos de 1 minuto · sem compromisso</p>';
          body.querySelector('[data-start]').addEventListener('click', () => { step = 1; render(); });
          return;
        }
        if (step >= 1 && step <= perguntas.length) {
          const idx = step - 1;
          const p = perguntas[idx];
          body.innerHTML =
            '<span class="diag__count">Pergunta ' + step + ' de ' + perguntas.length + '</span>' +
            '<h3 class="diag__q">' + esc(p.q) + '</h3>' +
            '<div class="diag__opts">' +
            p.opts.map((o, i) => '<button class="diag__opt' + (answers[idx] === o ? ' is-sel' : '') + '" data-opt="' + i + '">' + esc(o) + '</button>').join('') +
            '</div>' +
            (step > 1 ? '<button class="diag__back" data-back>← Voltar</button>' : '');
          body.querySelectorAll('[data-opt]').forEach((b) => b.addEventListener('click', () => {
            answers[idx] = p.opts[+b.getAttribute('data-opt')];
            step += 1; render();
          }));
          const back = body.querySelector('[data-back]');
          if (back) back.addEventListener('click', () => { step -= 1; render(); });
          return;
        }
        if (step === perguntas.length + 1) {
          body.innerHTML =
            '<span class="diag__count">Última etapa</span>' +
            '<h3 class="diag__q">Como podemos te chamar?</h3>' +
            '<input class="diag__input" type="text" placeholder="Seu nome" value="' + esc(nome) + '" data-nome autocomplete="given-name" />' +
            '<button class="btn btn--primary diag__next" data-finish>Ver meu diagnóstico →</button>' +
            '<button class="diag__back" data-back>← Voltar</button>';
          const input = body.querySelector('[data-nome]');
          input.focus();
          input.addEventListener('input', () => { nome = input.value; });
          input.addEventListener('keydown', (e) => { if (e.key === 'Enter') body.querySelector('[data-finish]').click(); });
          body.querySelector('[data-finish]').addEventListener('click', () => { nome = input.value.trim(); step += 1; render(); });
          body.querySelector('[data-back]').addEventListener('click', () => { step -= 1; render(); });
          return;
        }
        // resultado
        const ola = nome ? ('Boa, ' + nome + '! ') : 'Boa! ';
        let msg = 'Olá, Criativo 92! Fiz o diagnóstico no site.\n\n';
        if (nome) msg += 'Nome: ' + nome + '\n\n';
        perguntas.forEach((p, i) => { msg += '• ' + p.q + '\n→ ' + (answers[i] || '-') + '\n\n'; });
        msg += 'Quero um plano pra crescer.';
        const href = wa + '?text=' + encodeURIComponent(msg);
        body.innerHTML =
          '<span class="diag__eyebrow">Diagnóstico pronto</span>' +
          '<h3 class="diag__title">' + esc(ola) + 'seu negócio tem espaço pra crescer.</h3>' +
          '<p class="diag__lead">Com base nas suas respostas, montamos um plano sob medida. Clique abaixo e receba seu diagnóstico com os próximos passos direto no WhatsApp — sem compromisso.</p>' +
          '<a class="btn btn--primary diag__next" href="' + href + '" target="_blank" rel="noopener" data-diag-send>Receber no WhatsApp</a>' +
          '<button class="diag__back" data-back>← Revisar respostas</button>';
        body.querySelector('[data-back]').addEventListener('click', () => { step -= 1; render(); });
        return;
      }

      function open() {
        step = 0; render();
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      document.querySelectorAll('[data-open-diag]').forEach((b) => b.addEventListener('click', (e) => { e.preventDefault(); open(); }));
      modal.querySelectorAll('[data-diag-close]').forEach((b) => b.addEventListener('click', close));
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.classList.contains('is-open')) close(); });
      body.addEventListener('click', (e) => { if (e.target.closest('[data-diag-send]')) setTimeout(close, 300); });
    })();
  </script>
</LightLayout>

<style>
  /* ---------- diagnóstico (modal quiz) ---------- */
  .diag { position: fixed; inset: 0; z-index: 200; display: none; align-items: center; justify-content: center; padding: 1.2rem; }
  .diag.is-open { display: flex; }
  .diag__backdrop { position: absolute; inset: 0; background: rgba(4,12,8,0.74); backdrop-filter: blur(4px); }
  .diag__panel { position: relative; z-index: 1; width: 100%; max-width: 540px; background: var(--green-900); color: #eef2ef;
    border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: clamp(1.6rem, 4vw, 2.6rem);
    box-shadow: 0 40px 90px -30px rgba(0,0,0,0.65); max-height: 92vh; overflow-y: auto; animation: diag-in 0.3s var(--ease); }
  @keyframes diag-in { from { opacity: 0; transform: translateY(16px) scale(0.98); } to { opacity: 1; transform: none; } }
  .diag__x { position: absolute; top: 0.9rem; right: 0.9rem; width: 38px; height: 38px; border-radius: 50%; display: grid; place-items: center; color: #cdd8d1; background: rgba(255,255,255,0.06); transition: background 0.2s, color 0.2s; }
  .diag__x svg { width: 18px; height: 18px; }
  .diag__x:hover { background: rgba(255,255,255,0.14); color: #fff; }
  .diag__bar { height: 4px; background: rgba(255,255,255,0.12); border-radius: 99px; overflow: hidden; margin: 0.3rem 0 1.6rem; }
  .diag__bar span { display: block; height: 100%; width: 0; background: linear-gradient(90deg, var(--green-500), #45cd8c); border-radius: 99px; transition: width 0.4s var(--ease); }
  /* conteúdo injetado via JS -> precisa ser :global (sem hash de escopo) */
  :global(.diag__eyebrow), :global(.diag__count) { display: block; color: #7fd0a9; font-weight: 700; font-size: 0.76rem; letter-spacing: 0.09em; text-transform: uppercase; margin-bottom: 0.5rem; }
  :global(.diag__title) { color: #fff; font-size: clamp(1.4rem, 1.1rem + 1vw, 1.9rem); line-height: 1.1; margin: 0 0 0.7rem; letter-spacing: -0.02em; }
  :global(.diag__q) { color: #fff; font-size: clamp(1.2rem, 1rem + 0.7vw, 1.5rem); line-height: 1.15; margin: 0.4rem 0 1.2rem; letter-spacing: -0.02em; }
  :global(.diag__lead) { color: #b9c6bf; line-height: 1.55; margin-bottom: 1.4rem; }
  :global(.diag__opts) { display: flex; flex-direction: column; gap: 0.6rem; }
  :global(.diag__opt) { text-align: left; width: 100%; padding: 0.9rem 1.1rem; border-radius: 12px; border: 1.5px solid rgba(255,255,255,0.16); color: #eef2ef; font-weight: 600; transition: border-color 0.2s, background 0.2s, transform 0.15s; }
  :global(.diag__opt:hover) { border-color: #7fd0a9; background: rgba(127,208,169,0.08); transform: translateX(2px); }
  :global(.diag__opt.is-sel) { border-color: var(--green-500); background: rgba(30,122,86,0.28); }
  :global(.diag__input) { width: 100%; padding: 0.9rem 1.1rem; border-radius: 12px; border: 1.5px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.05); color: #fff; font-size: 1rem; margin-bottom: 1.2rem; }
  :global(.diag__input::placeholder) { color: #8fa79b; }
  :global(.diag__input:focus) { outline: none; border-color: #7fd0a9; }
  :global(.diag__next) { width: 100%; justify-content: center; margin-top: 0.4rem; }
  :global(.diag__mini) { color: #8fa79b; font-size: 0.8rem; text-align: center; margin-top: 0.85rem; }
  :global(.diag__back) { display: inline-block; margin-top: 1rem; color: #8fa79b; font-weight: 600; font-size: 0.9rem; background: none; cursor: pointer; }
  :global(.diag__back:hover) { color: #7fd0a9; }

  /* ---------- TESTE: folhas de fundo (bg-neutro) — marca d'água suave ---------- */
  #servicos::before, #faq::before, #depoimentos::before, #contato::before {
    content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-repeat: no-repeat; background-size: cover; }
  /* seções claras -> folhas brancas (folha à esquerda) */
  #servicos { background-color: var(--paper); }
  #servicos::before { background-image: url('/bg/leaf-branco-3.webp'); background-position: left center; opacity: 0.15; }
  #faq { background-color: var(--paper); }
  #faq::before { background-image: url('/bg/leaf-faq.webp'); background-position: right center; opacity: 0.15; transform: scaleX(-1); }
  /* seções escuras -> folhas verdes (folha à direita) */
  #depoimentos::before { background-image: url('/bg/leaf-verde-2.webp'); background-position: right center; opacity: 0.5; }
  #contato::before { background-image: url('/bg/leaf-verde-1.webp'); background-position: right center; opacity: 0.55; }

  /* ---------- header ---------- */
  .hd { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: transparent; border-bottom: 1px solid transparent;
    transition: background 0.3s, backdrop-filter 0.3s, border-color 0.3s; }
  .hd.is-stuck { background: rgba(8, 23, 16, 0.72); backdrop-filter: blur(12px); border-bottom-color: rgba(255,255,255,0.10); }
  .hd__in { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; height: 70px; }
  .hd__logo { display: inline-flex; align-items: center; }
  .hd__logo img { height: 34px; width: auto; display: block; }
  .ft__logo img { height: 46px; width: auto; display: block; }
  .hd__nav { display: flex; gap: 1.8rem; }
  .hd__nav a { font-weight: 500; font-size: 0.95rem; color: #eaf1ec; transition: color 0.2s; text-shadow: 0 1px 8px rgba(0,0,0,0.25); }
  .hd__nav a:hover { color: #7fd0a9; }
  .hd__cta { padding: 0.6em 1.1em; font-size: 0.92rem; }
  /* botão hambúrguer (só mobile) */
  .hd__burger { display: none; flex-direction: column; justify-content: center; gap: 5px; width: 44px; height: 44px; margin-right: -8px; }
  .hd__burger span { display: block; width: 24px; height: 2px; border-radius: 2px; background: #fff; margin-inline: auto; transition: transform 0.3s var(--ease), opacity 0.2s; }
  .hd.menu-open .hd__burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hd.menu-open .hd__burger span:nth-child(2) { opacity: 0; }
  .hd.menu-open .hd__burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  /* painel do menu mobile */
  .hd__mobile { display: none; flex-direction: column; gap: 0.35rem; padding: 0.6rem clamp(1.25rem, 4vw, 3.5rem) 1.4rem;
    background: rgba(8, 23, 16, 0.97); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10); }
  .hd.menu-open .hd__mobile { display: flex; }
  .hd__mobile nav { display: flex; flex-direction: column; }
  .hd__mobile nav a { padding: 0.85rem 0.2rem; color: #eaf1ec; font-weight: 600; font-size: 1.05rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .hd__mobile nav a:active { color: #7fd0a9; }
  .hd__mobile .btn { margin-top: 0.9rem; justify-content: center; }
  @media (max-width: 820px) {
    .hd__nav { display: none; }
    .hd__cta { display: none; }
    .hd__burger { display: flex; }
  }

  /* ---------- hero ---------- */
  /* HERO escuro — texto e foto lado a lado, foto colada no fim (bottom-flush) */
  .hero { position: relative; min-height: clamp(520px, 70vh, 690px); display: flex; align-items: center; overflow: hidden;
    background-color: #06170f; color: #e9f1ec; }
  .hero::before { content: ''; position: absolute; inset: 0; z-index: 0;
    background: url('/bg-hero-section.webp') center right / cover no-repeat; }
  .hero::after { content: ''; position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(90deg, rgba(4,17,11,0.94) 0%, rgba(4,17,11,0.82) 30%, rgba(4,17,11,0.45) 52%, rgba(4,17,11,0.12) 74%, rgba(4,17,11,0.05) 100%); }
  .hero__inner { position: relative; z-index: 2; width: 100%; padding-inline: clamp(1.5rem, 3.8vw, 3.5rem); }
  .hero__col { max-width: 470px; padding-block: clamp(0.5rem, 2vh, 1.5rem); }
  .hero__title { font-size: clamp(1.7rem, 0.9rem + 2vw, 2.95rem); line-height: 1.06; letter-spacing: -0.035em; color: #fff; margin: 1rem 0 1.1rem; }
  .hero__title :global(.accent) { color: #45cd8c; }
  .hero .eyebrow, .hero .eyebrow::before { color: #7fd0a9; }
  .hero .eyebrow::before { background: #7fd0a9; }
  .hero__lead { color: #b7c7bf; margin-bottom: 1.5rem; font-size: clamp(0.82rem, 0.76rem + 0.24vw, 0.94rem); line-height: 1.5; max-width: none; }
  .hero__cta { display: flex; flex-wrap: nowrap; gap: 0.7rem; margin-bottom: 1.4rem; }
  .hero .btn { padding: 0.78em 1.2em; font-size: 0.92rem; white-space: nowrap; }
  .hero .btn--ghost { border-color: rgba(255,255,255,0.26); color: #eaf1ec; }
  .hero .btn--ghost:hover { border-color: #7fd0a9; color: #fff; }
  .hero__badges { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .hero .badge { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.16); color: #cdd8d1; }

  /* desktop/tablet usam a imagem de fundo → foto recortada escondida */
  .hero__photo { display: none; }
  .hero__photo::before { display: none; }
  .hero__photo img { width: 100%; height: auto; display: block; }

  /* tablet: mantém a imagem de fundo, só ajusta enquadramento */
  @media (max-width: 900px) {
    .hero { min-height: clamp(520px, 66vh, 640px); }
    .hero__col { max-width: 60%; }
    .hero::before { background-position: 78% center; }
  }

  /* mobile: layout centralizado + fundo em degradê + foto recortada dos sócios */
  @media (max-width: 640px) {
    .hero { min-height: auto; display: block;
      background: radial-gradient(118% 100% at 50% 8%, #12492f 0%, var(--green-900) 52%, #06170f 100%); }
    .hero::before, .hero::after { display: none; }
    .hero__col { max-width: none; text-align: center; padding-top: clamp(5rem, 16vw, 6.5rem); padding-bottom: 1rem; }
    .hero__lead { margin-left: auto; margin-right: auto; max-width: 42ch; }
    .hero__cta { justify-content: center; flex-wrap: wrap; }
    .hero__cta .btn { flex: 1 1 auto; justify-content: center; }
    .hero__eyebrow-full { display: none; }
    .hero .eyebrow::before { display: none; }
    .hero__badges { justify-content: center; flex-wrap: nowrap; gap: 0.5rem; }
    .hero__badges .badge { font-size: 0.74rem; padding: 0.4em 0.7em; white-space: nowrap; }
    .hero__photo { display: block; position: relative; right: auto; bottom: auto; width: 100%; max-width: 580px; margin: 0.5rem auto 0; z-index: 1; }
  }

  /* ---------- trust ---------- */
  .trust { background: var(--green-900); padding-block: clamp(1.8rem, 4vw, 2.6rem); overflow: hidden; }
  .trust__label { display: block; text-align: center; color: #8fa79b; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em; margin-bottom: clamp(1.2rem, 3vw, 1.8rem); }
  .trust__marquee { overflow: hidden;
    -webkit-mask: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
    mask: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent); }
  .trust__track { display: flex; align-items: center; gap: clamp(2.2rem, 5vw, 4.5rem); width: max-content; animation: trust-scroll 55s linear infinite; }
  .trust__logo { height: clamp(49px, 6.1vw, 78px); width: auto; object-fit: contain; filter: grayscale(1) brightness(1.15); opacity: 0.62; transition: opacity 0.3s, filter 0.3s; flex: 0 0 auto; }
  .trust__logo:hover { opacity: 0.95; filter: grayscale(1) brightness(1.35); }
  @keyframes trust-scroll { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) {
    .trust__track { animation: none; flex-wrap: wrap; justify-content: center; width: auto; row-gap: 1.5rem; }
  }

  /* ---------- section heads ---------- */
  .sec-head { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2rem; align-items: end; margin-bottom: clamp(2.2rem, 5vw, 3.5rem); }
  .sec-head .h2 { margin-top: 0.9rem; }
  .sec-head .lead { justify-self: end; }
  @media (max-width: 760px) { .sec-head { grid-template-columns: 1fr; gap: 1rem; } .sec-head .lead { justify-self: start; } }

  /* ---------- números ---------- */
  /* números: foto do escritório ao fundo, opacidade 0% (topo) -> 50% (base) */
  .nums { position: relative; overflow: hidden; background: #0B1815; }
  .nums::before { content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background: url('/fotos/escritorio-c92.jpg') center / cover no-repeat; opacity: 0.5;
    -webkit-mask: linear-gradient(180deg, transparent 0%, #000 100%); mask: linear-gradient(180deg, transparent 0%, #000 100%); }
  .nums > .container { position: relative; z-index: 1; }
  .nums__head { margin-bottom: clamp(2rem, 5vw, 3.2rem); }
  .nums__head .h2 { margin-top: 0.8rem; }
  .nums__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.2rem, 3vw, 2.5rem); }
  .nums__item { border-top: 2px solid rgba(255,255,255,0.16); padding-top: 1.1rem; }
  .nums__n { display: block; font-weight: 800; font-size: clamp(2.4rem, 1.6rem + 3vw, 4rem); letter-spacing: -0.04em; color: #fff; }
  .nums__l { color: #9fb3aa; font-size: 0.95rem; }

  /* sobre a C92 */
  .sobre__grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .sobre__img { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line); }
  .sobre__img img { width: 100%; height: 100%; max-height: 520px; object-fit: cover; display: block; }
  .sobre__body .h2 { margin: 0.9rem 0 1.2rem; }
  .sobre__objs { display: flex; flex-direction: column; gap: 0.9rem; margin-top: 1.6rem; }
  .sobre__objs li { position: relative; padding-left: 1.4rem; color: var(--ink-soft); }
  .sobre__objs li::before { content: ''; position: absolute; left: 0; top: 0.55em; width: 8px; height: 8px; border-radius: 50%; background: var(--green-600); }
  .sobre__objs strong { color: var(--ink); }
  @media (max-width: 820px) { .sobre__grid { grid-template-columns: 1fr; } .sobre__img img { max-height: 340px; } }
  @media (max-width: 720px) { .nums__grid { grid-template-columns: 1fr 1fr; } }

  /* ---------- serviços ---------- */
  .svc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
  .svc { position: relative; padding: 1.7rem; border: 1px solid var(--line); border-radius: var(--radius); background: #fff; transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s var(--ease), background 0.3s var(--ease); overflow: hidden; }
  .svc::after { content: ''; position: absolute; left: 0; top: 0; height: 3px; width: 0; background: var(--green-500); transition: width 0.35s var(--ease); }
  .svc:hover { background: var(--ink); border-color: var(--ink); box-shadow: 0 24px 50px -34px rgba(10,36,27,0.45); transform: translateY(-3px); }
  .svc:hover::after { width: 100%; }
  .svc::before { content: ''; position: absolute; inset: 0; z-index: 0; background: var(--svc-img) center / cover no-repeat; opacity: 0; transition: opacity 0.45s var(--ease); border-radius: inherit; }
  .svc:hover::before { opacity: 0.15; }
  .svc__n, .svc__t, .svc__d { position: relative; z-index: 1; }
  .svc__n { font-weight: 800; font-size: 0.9rem; color: var(--green-600); transition: color 0.3s; }
  .svc__t { font-size: 1.22rem; margin: 0.9rem 0 0.5rem; transition: color 0.3s; }
  .svc__d { color: var(--muted); font-size: 0.96rem; transition: color 0.3s; }
  .svc:hover .svc__n { color: #7fd0a9; }
  .svc:hover .svc__t { color: #fff; }
  .svc:hover .svc__d { color: #b9c2ba; }
  .svc__arrow { position: absolute; top: 1.7rem; right: 1.7rem; color: var(--green-600); opacity: 0; transform: translateX(-6px); transition: opacity 0.25s, transform 0.25s var(--ease); }
  .svc:hover .svc__arrow { opacity: 1; transform: none; }
  @media (max-width: 900px) { .svc-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .svc-grid { grid-template-columns: 1fr; } }

  /* ---------- método ---------- */
  .steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.4rem; }
  .step { list-style: none; }
  .step__btn { position: relative; display: flex; flex-direction: column; width: 100%; text-align: left; background: none; border: 0; cursor: pointer; padding: 1.1rem 0 0; border-top: 2px solid var(--line-strong); opacity: 0.5; transition: opacity 0.35s; }
  .step.is-active .step__btn, .step__btn:hover { opacity: 1; }
  .step__bar { position: absolute; top: -2px; left: 0; height: 2px; width: 0; background: var(--green-700); }
  .step.is-active .step__bar { animation: step-fill var(--dur, 6s) linear forwards; }
  @keyframes step-fill { from { width: 0; } to { width: 100%; } }
  .step__n { font-weight: 800; color: var(--green-600); font-size: 0.9rem; }
  .step__t { font-size: 1.18rem; font-weight: 800; letter-spacing: -0.02em; color: var(--ink); margin: 0.7rem 0 0.5rem; }
  .step__d { color: var(--muted); font-size: 0.95rem; }

  /* caixa rotativa que explica cada etapa */
  .mfeat { position: relative; margin-top: clamp(1.6rem, 3.5vw, 2.8rem); }
  .mfeat__panel { display: none; grid-template-columns: 0.85fr 1.15fr; gap: clamp(1.4rem, 3vw, 2.5rem); align-items: stretch; }
  .mfeat__panel[data-active="true"] { display: grid; animation: mfeat-in 0.55s var(--ease); }
  @keyframes mfeat-in { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
  .mfeat__img { position: relative; min-height: clamp(220px, 26vw, 300px); border-radius: var(--radius); overflow: hidden; background: var(--green-900); }
  .mfeat__photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .mfeat__badge { position: absolute; top: 1rem; left: 1rem; z-index: 2; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; background: rgba(255,255,255,0.14); color: #fff; padding: 0.35em 0.8em; border-radius: 999px; }
  .mfeat__ghost { position: absolute; right: 0.6rem; bottom: -2.6rem; font-weight: 900; font-size: clamp(9rem, 18vw, 15rem); line-height: 1; color: rgba(255,255,255,0.06); z-index: 0; }
  .mfeat__icon { position: relative; z-index: 1; width: clamp(56px, 9vw, 92px); color: #eafaf1; }
  .mfeat__icon :global(svg) { width: 100%; height: auto; }
  .mfeat__body { display: flex; flex-direction: column; justify-content: center; }
  .mfeat__n { font-weight: 800; color: var(--green-700); font-size: 1.05rem; margin-bottom: 0.9rem; }
  .mfeat__long { font-size: clamp(1.05rem, 0.98rem + 0.5vw, 1.35rem); line-height: 1.55; color: var(--ink); max-width: 42ch; }

  /* seções do meio com fundo escuro */
  .panel-dark .eyebrow { color: #7fd0a9; }
  .panel-dark .eyebrow::before { background: #7fd0a9; }
  #metodo .step__btn { border-top-color: rgba(255,255,255,0.16); }
  #metodo .step__t { color: #fff; }
  #metodo .step__d { color: #9fb3aa; }
  #metodo .step__n { color: #7fd0a9; }
  #metodo .mfeat__n { color: #7fd0a9; }
  #metodo .mfeat__long { color: #e9f1ec; }
  #depoimentos .deps-hint { color: #9fb3aa; }
  #depoimentos .deps-btn { border-color: rgba(255,255,255,0.25); color: #eaf1ec; }
  #depoimentos .deps-btn:hover { border-color: var(--green-500); background: var(--green-600); color: #fff; }

  @media (max-width: 820px) { .steps { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 760px) { .mfeat__panel[data-active="true"] { grid-template-columns: 1fr; } }
  @media (max-width: 460px) { .steps { grid-template-columns: 1fr; } }

  /* ---------- cases ---------- */
  /* cases em destaque — um bloco largo por case */
  .feats { display: flex; flex-direction: column; gap: 1.2rem; margin-bottom: clamp(3rem, 6vw, 5rem); }
  .feat { display: grid; grid-template-columns: 0.85fr 1.4fr; align-items: stretch; border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; background: #fff; transition: box-shadow .3s, transform .3s var(--ease); }
  .feat:hover { box-shadow: 0 30px 60px -40px rgba(10,36,27,0.35); transform: translateY(-3px); }
  .feat__panel { position: relative; overflow: hidden; color: #fff; min-height: clamp(210px, 24vw, 280px); }
  .feat__photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .feat__overlay { position: absolute; inset: 0; z-index: 1; display: flex; flex-direction: column; justify-content: flex-end; gap: 0.2rem; padding: clamp(1.5rem, 3vw, 2.2rem); background: linear-gradient(180deg, rgba(6,23,15,0.05) 25%, rgba(6,23,15,0.55) 62%, rgba(6,23,15,0.9) 100%); }
  .feat__tag { font-size: 0.76rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #9fdcbf; }
  .feat__metric { font-weight: 800; font-size: clamp(2.4rem, 1.7rem + 3vw, 4.2rem); letter-spacing: -0.035em; line-height: 1; margin-top: 0.4rem; color: #fff; }
  .feat__unit { color: #bfe0cf; font-weight: 600; font-size: 0.95rem; }
  .feat__body { display: flex; flex-direction: column; justify-content: center; padding: clamp(1.6rem, 3vw, 2.4rem) clamp(1.6rem, 3vw, 2.6rem); }
  .feat__nome { font-size: clamp(1.6rem, 1.2rem + 1.6vw, 2.4rem); margin-bottom: 0.6rem; }
  .feat__desc { color: var(--ink-soft); font-size: 1.02rem; line-height: 1.55; margin-bottom: 1.4rem; max-width: 54ch; }
  .feat__servicos { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .feat__servicos li { font-size: 0.78rem; font-weight: 600; color: var(--green-700); background: var(--green-050); border-radius: 999px; padding: 0.4em 0.9em; }
  @media (max-width: 780px) { .feat { grid-template-columns: 1fr; } }

  /* grade de todos os clientes */
  .clientes-title { text-align: center; font-size: clamp(1.3rem, 1rem + 1.1vw, 1.75rem); margin-bottom: clamp(1.8rem, 4vw, 2.6rem); }
  .clientes-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.9rem; }
  .cliente { position: relative; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.7rem; padding: 1.3rem 1rem; border: 1px solid var(--line); border-radius: var(--radius); background: #fff; transition: border-color .25s, box-shadow .25s, transform .25s var(--ease); }
  .cliente:hover { border-color: var(--line-strong); box-shadow: 0 18px 40px -30px rgba(10,36,27,0.25); transform: translateY(-2px); }
  /* feixe verde animado circulando a borda */
  @property --c92-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .cliente::before {
    content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px; pointer-events: none; z-index: 2;
    background: conic-gradient(from var(--c92-angle), transparent 0deg 240deg, var(--green-500) 300deg, #3fe0a0 330deg, var(--green-500) 355deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor; mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s;
  }
  .cliente:hover::before { opacity: 1; animation: c92-spin 3.5s linear infinite; }
  @keyframes c92-spin { to { --c92-angle: 360deg; } }
  @media (prefers-reduced-motion: reduce) { .cliente:hover::before { animation: none; } }
  .cliente__logo { width: 100%; height: 85px; display: grid; place-items: center; background: var(--green-900); border-radius: 9px; padding: 0 1rem; }
  .cliente__logo img { max-height: 51px; max-width: 100%; object-fit: contain; filter: grayscale(1) brightness(1.3); opacity: 0.9; }
  .cliente__nome { font-weight: 700; font-size: 0.92rem; color: var(--ink); line-height: 1.2; }
  .cliente__seg { font-size: 0.76rem; color: var(--muted); }
  /* no mobile vira slide horizontal (rola da esquerda p/ a direita) */
  @media (max-width: 760px) {
    .clientes-grid { display: flex; flex-wrap: nowrap; overflow-x: auto; scroll-snap-type: x mandatory;
      gap: 0.9rem; scrollbar-width: none; -ms-overflow-style: none;
      margin-inline: calc(var(--gutter) * -1); padding: 0.4rem var(--gutter) 0.6rem; }
    .clientes-grid::-webkit-scrollbar { display: none; }
    .cliente { flex: 0 0 74%; scroll-snap-align: start; }
  }

  /* ---------- depoimentos ---------- */
  .deps-carousel { overflow-x: auto; scroll-snap-type: x proximity; scrollbar-width: none; -ms-overflow-style: none; cursor: grab; margin-inline: calc(var(--gutter) * -1); padding: 0.4rem var(--gutter); }
  .deps-carousel::-webkit-scrollbar { display: none; }
  .deps-carousel.is-dragging { cursor: grabbing; scroll-snap-type: none; user-select: none; }
  .deps-track { display: flex; gap: 1.1rem; width: max-content; }
