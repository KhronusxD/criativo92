    <!-- ============ FAQ ============ -->
    <section class="section" id="faq">
      <div class="container faq">
        <header class="faq__head" data-reveal>
          <span class="eyebrow">Dúvidas frequentes</span>
          <h2 class="h2">Perguntas que a gente sempre ouve.</h2>
