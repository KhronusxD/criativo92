---
import LightLayout from '../../layouts/LightLayout.astro';
import { lpVB, VB_OFERTA, VB_GARANTIAS, VB_CTA } from '../../data/lp-vb.js';

export function getStaticPaths() {
  return Object.keys(lpVB).map((slug) => ({ params: { nicho: slug }, props: { d: lpVB[slug] } }));
}
const { d } = Astro.props;
const cta = { ...VB_CTA, href: d.diagUrl };
---

<LightLayout title={d.meta.title} description={d.meta.description}>
  <!-- header slim -->
  <header class="vhd" data-vhd>
    <div class="vhd__in">
      <a href={`/${d.slug}`} class="vhd__logo" aria-label="Criativo 92"><img src="/logo-c92.png" alt="Criativo 92" /></a>
      <a href={cta.href} class="btn btn--primary vhd__cta">Diagnóstico gratuito</a>
    </div>
  </header>

  <main class="vb">
    <!-- HERO -->
    <section class="vhero">
      <div class="vwrap">
        <p class="vhero__kicker" data-reveal>{d.hero.kicker}</p>
        <h1 class="vhero__h1" data-reveal data-reveal-delay="1">{d.hero.headline}</h1>
        <p class="vhero__sub" data-reveal data-reveal-delay="2">{d.hero.sub}</p>
        <div class="vcta" data-reveal data-reveal-delay="3">
          <a href={cta.href} class="btn btn--cta">{cta.label}</a>
          <span class="vcta__sub">{cta.sub}</span>
        </div>
        <ul class="vhero__badges" data-reveal data-reveal-delay="3">
          {d.hero.badges.map((b) => <li><span class="dot"></span>{b}</li>)}
        </ul>
      </div>
    </section>

    <!-- LEAD / ABERTURA -->
    <section class="vsec vsec--paper">
      <div class="vwrap vprose" data-reveal>
        {d.lead.map((p) => <p>{p}</p>)}
      </div>
    </section>

    <!-- PROBLEMA + AGITAÇÃO -->
    <section class="vsec">
      <div class="vwrap">
        <h2 class="vh2" data-reveal>{d.problema.titulo}</h2>
        <p class="vlead" data-reveal>{d.problema.intro}</p>
        <ul class="vpains">
          {d.problema.bullets.map((b, i) => (
            <li data-reveal data-reveal-delay={String((i % 2) + 1)}>
              <span class="vx"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg></span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
        <p class="vfecho" data-reveal>{d.problema.fecho}</p>
      </div>
    </section>

    <!-- MECANISMO -->
    <section class="vsec vsec--dark">
      <div class="vwrap">
        <p class="veyebrow" data-reveal>A virada</p>
        <p class="vmec__intro" data-reveal>{d.mecanismo.intro}</p>
        <h2 class="vh2 vh2--light" data-reveal>{d.mecanismo.destaque}</h2>
        <ol class="vmec">
          {d.mecanismo.pontos.map((p, i) => (
            <li data-reveal data-reveal-delay={String((i % 3) + 1)}>
              <span class="vmec__n">{String(i + 1).padStart(2, '0')}</span>
              <div><h3>{p.t}</h3><p>{p.d}</p></div>
            </li>
          ))}
        </ol>
        <p class="vfecho vfecho--light" data-reveal>{d.mecanismo.fecho}</p>
      </div>
    </section>

    <!-- SOLUÇÃO -->
    <section class="vsec vsec--paper">
      <div class="vwrap">
        <p class="veyebrow" data-reveal>A solução</p>
        <h2 class="vh2" data-reveal>É exatamente isso que a Criativo 92 faz.</h2>
        <p class="vlead" data-reveal>{d.solucao.intro}</p>
        <ul class="vchecks">
          {d.solucao.itens.map((it, i) => (
            <li data-reveal data-reveal-delay={String((i % 2) + 1)}>
              <span class="vcheck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></span>
              <span>{it}</span>
            </li>
          ))}
        </ul>
        <p class="vfecho" data-reveal>{d.solucao.fecho}</p>
        <div class="vcta vcta--center" data-reveal>
          <a href={cta.href} class="btn btn--cta">{cta.label}</a>
        </div>
      </div>
    </section>

    <!-- BENEFÍCIOS -->
    <section class="vsec">
      <div class="vwrap">
        <h2 class="vh2 vh2--center" data-reveal>O que muda no seu negócio.</h2>
        <ul class="vbenes">
          {d.beneficios.map((b, i) => (
            <li data-reveal data-reveal-delay={String((i % 3) + 1)}>
              <span class="vbene__i">{b.i}</span>
              <span>{b.t}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- PROVA -->
    <section class="vsec vsec--dark">
      <div class="vwrap">
        <p class="veyebrow" data-reveal>Prova real</p>
        <h2 class="vh2 vh2--light vh2--center" data-reveal>Não é promessa. É resultado publicado.</h2>
        <div class="vprova" data-reveal data-reveal-delay="1">
          <div class="vprova__media">
            <video class="vprova__video" src={d.prova.video.src} poster={d.prova.video.poster} playsinline preload="metadata"></video>
            <button class="vprova__play" type="button" data-vplay aria-label="Assistir case">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M8 5v14l11-7z" /></svg>
            </button>
          </div>
          <div class="vprova__body">
            <span class="vprova__stat">{d.prova.stat.n}</span>
            <span class="vprova__statl">{d.prova.stat.l}</span>
            <blockquote class="vprova__q">“{d.prova.depo.q}”</blockquote>
            <span class="vprova__quem"><strong>{d.prova.depo.quem}</strong> · {d.prova.depo.loja}</span>
          </div>
        </div>
        <p class="vprova__logos" data-reveal>Óticas Veja · Rações Fortaleza · Celularis · iPro · House Vision · +100 marcas de todo o Amazonas</p>
      </div>
    </section>

    <!-- OFERTA -->
    <section class="vsec vsec--paper">
      <div class="vwrap">
        <p class="veyebrow" data-reveal>{VB_OFERTA.eyebrow}</p>
        <h2 class="vh2" data-reveal>{VB_OFERTA.titulo}</h2>
        <p class="vlead" data-reveal>{VB_OFERTA.intro}</p>
        <ul class="voferta">
          {VB_OFERTA.itens.map((it, i) => (
            <li data-reveal data-reveal-delay={String((i % 2) + 1)}>
              <span class="voferta__i">{it.i}</span>
              <span>{it.t}</span>
            </li>
          ))}
        </ul>
        <p class="vfecho" data-reveal>{VB_OFERTA.fecho}</p>
      </div>
    </section>

    <!-- GARANTIAS -->
    <section class="vsec">
      <div class="vwrap">
        <ul class="vgar">
          {VB_GARANTIAS.map((g, i) => (
            <li data-reveal data-reveal-delay={String((i % 3) + 1)}>
              <span class="vgar__i">{g.i}</span>
              <h3>{g.t}</h3>
              <p>{g.d}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section class="vsec vsec--paper">
      <div class="vwrap vwrap--narrow">
        <h2 class="vh2 vh2--center" data-reveal>Perguntas que a gente sempre ouve.</h2>
        <ul class="vfaq">
          {d.faq.map((f) => (
            <li class="vfaq__item" data-reveal>
              <button class="vfaq__q" type="button" data-faq aria-expanded="false">
                <span>{f.q}</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path class="vfaq__v" d="M12 5v14"/></svg>
              </button>
              <div class="vfaq__a"><p>{f.a}</p></div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- FECHAMENTO -->
    <section class="vsec vsec--dark vclose">
      <div class="vwrap" data-reveal>
        <h2 class="vh2 vh2--light vh2--center">{d.fechamento.p1}</h2>
        <p class="vlead vlead--light vlead--center">{d.fechamento.p2}</p>
        <div class="vcta vcta--center">
          <a href={cta.href} class="btn btn--cta">{cta.label}</a>
          <span class="vcta__sub vcta__sub--light">{cta.sub}</span>
        </div>
        <p class="vps"><strong>P.S.</strong> {d.fechamento.ps}</p>
      </div>
    </section>
  </main>

  <footer class="vft">
    <div class="vwrap vft__in">
      <span>© 2026 Criativo 92 · Marketing e estratégia com método. Manaus, Amazonas.</span>
      <a href={`/${d.slug}`}>Ver versão completa do site →</a>
    </div>
  </footer>

  <!-- CTA fixo mobile -->
  <a href={cta.href} class="vsticky">Fazer diagnóstico gratuito</a>

  <script>
    // FAQ
    document.querySelectorAll('[data-faq]').forEach((btn) => {
      const item = btn.closest('.vfaq__item');
      const ans = item.querySelector('.vfaq__a');
      btn.addEventListener('click', () => {
        const open = item.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        ans.style.maxHeight = open ? ans.scrollHeight + 'px' : '0';
      });
    });
    // vídeo de prova
    const pv = document.querySelector('[data-vplay]');
    if (pv) {
      pv.addEventListener('click', () => {
        const v = pv.previousElementSibling;
        v.setAttribute('controls', '');
        pv.style.display = 'none';
        v.play();
      });
    }
    // header ganha fundo ao rolar
    const vhd = document.querySelector('[data-vhd]');
    if (vhd) {
      const on = () => vhd.classList.toggle('is-stuck', window.scrollY > 8);
      on(); window.addEventListener('scroll', on, { passive: true });
    }
  </script>

  <style is:global>
    /* ============ Versão B — sales page ============ */
    .vb { --vgreen: #124b36; --vgreen2: #1e7a56; }
    .vwrap { width: 100%; max-width: 760px; margin-inline: auto; padding-inline: clamp(1.25rem, 5vw, 2rem); }
    .vwrap--narrow { max-width: 680px; }
    .vsec { padding-block: clamp(3rem, 7vw, 5.5rem); }
    .vsec--paper { background: var(--paper); }
    .vsec--dark { background: #0a241b; color: #dfeae4; }

    .veyebrow { display: inline-block; color: var(--green-600); font-weight: 800; font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 0.9rem; }
    .vsec--dark .veyebrow { color: #7fd0a9; }
    .vh2 { font-size: clamp(1.7rem, 1.2rem + 2vw, 2.6rem); line-height: 1.1; letter-spacing: -0.03em; color: var(--ink); }
    .vh2--light { color: #fff; }
    .vh2--center { text-align: center; }
    .vlead { color: var(--ink-soft); font-size: clamp(1.05rem, 1rem + 0.4vw, 1.2rem); line-height: 1.6; margin-top: 1rem; }
    .vlead--light { color: #b9c6bf; }
    .vlead--center { text-align: center; margin-inline: auto; max-width: 60ch; }
    .vfecho { margin-top: 1.5rem; font-weight: 700; font-size: 1.1rem; color: var(--green-700); letter-spacing: -0.01em; }
    .vfecho--light { color: #9fe0bf; }

    /* header */
    .vhd { position: fixed; top: 0; left: 0; right: 0; z-index: 100; transition: background .3s, box-shadow .3s; }
    .vhd.is-stuck { background: rgba(8,23,16,.82); backdrop-filter: blur(12px); }
    .vhd__in { max-width: 1000px; margin-inline: auto; display: flex; align-items: center; justify-content: space-between; padding: 0.7rem clamp(1rem, 4vw, 2rem); }
    .vhd__logo img { height: 30px; display: block; }
    .vhd__cta { padding: 0.55em 1em; font-size: 0.9rem; }

    /* hero */
    .vhero { background: radial-gradient(120% 100% at 80% -10%, #12492f 0%, #0a241b 52%, #06170f 100%); color: #eaf1ec; padding: clamp(6rem, 15vw, 8.5rem) 0 clamp(3rem, 8vw, 5rem); text-align: center; }
    .vhero__kicker { max-width: 60ch; margin: 0 auto 1.4rem; color: #9fc7b2; font-weight: 600; font-size: 0.98rem; line-height: 1.5; }
    .vhero__h1 { font-size: clamp(2rem, 1.3rem + 3.4vw, 3.5rem); line-height: 1.06; letter-spacing: -0.035em; color: #fff; }
    .vhero__sub { max-width: 62ch; margin: 1.5rem auto 0; color: #c2d3ca; font-size: clamp(1.02rem, 0.97rem + 0.4vw, 1.18rem); line-height: 1.6; }
    .vhero__badges { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.7rem; margin-top: 2rem; }
    .vhero__badges li { display: inline-flex; align-items: center; gap: 0.5em; padding: 0.45em 0.9em; border: 1px solid rgba(255,255,255,.16); border-radius: 999px; font-size: 0.85rem; color: #cdd8d1; background: rgba(255,255,255,.05); }
    .vhero__badges .dot { width: 7px; height: 7px; border-radius: 50%; background: #45cd8c; }

    /* CTA */
    .btn--cta { background: #1e7a56; color: #fff; font-weight: 800; font-size: clamp(1rem, 0.95rem + 0.4vw, 1.15rem); padding: 1.05em 1.9em; border-radius: 12px; box-shadow: 0 16px 40px -16px rgba(30,122,86,.7); }
    .btn--cta:hover { background: #23926a; }
    .vcta { margin-top: 2rem; display: flex; flex-direction: column; align-items: center; gap: 0.8rem; }
    .vcta--center { align-items: center; text-align: center; }
    .vcta__sub { color: #9fc7b2; font-size: 0.92rem; max-width: 42ch; }
    .vcta__sub--light { color: #9fc7b2; }
    .vsec--paper .vcta__sub, .vsec:not(.vsec--dark) .vcta__sub { color: var(--muted); }

    /* prose (lead) */
    .vprose p { color: var(--ink-soft); font-size: clamp(1.08rem, 1rem + 0.5vw, 1.28rem); line-height: 1.7; margin-bottom: 1.1rem; }
    .vprose p:first-child { font-weight: 700; color: var(--ink); }

    /* pains */
    .vpains { display: grid; gap: 0.7rem; margin-top: 1.8rem; }
    .vpains li { display: flex; gap: 0.85rem; align-items: flex-start; background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 1rem 1.15rem; color: var(--ink-soft); line-height: 1.5; }
    .vsec--paper .vpains li { background: #fff; }
    .vx { flex: 0 0 auto; width: 28px; height: 28px; border-radius: 8px; display: grid; place-items: center; background: #fbecea; color: #d0563f; }
    .vx svg { width: 14px; height: 14px; }

    /* mecanismo */
    .vmec__intro { color: #9fc7b2; font-weight: 600; margin-bottom: 0.6rem; }
    .vmec { list-style: none; display: grid; gap: 1.1rem; margin-top: 1.8rem; }
    .vmec li { display: flex; gap: 1rem; align-items: flex-start; padding: 1.3rem; background: rgba(255,255,255,.045); border: 1px solid rgba(255,255,255,.12); border-radius: 14px; }
    .vmec__n { flex: 0 0 auto; color: #45cd8c; font-weight: 800; font-size: 1.1rem; }
    .vmec h3 { color: #fff; font-size: 1.15rem; letter-spacing: -0.02em; margin-bottom: 0.35rem; }
    .vmec p { color: #b9c6bf; line-height: 1.55; }

    /* checks (solução) */
    .vchecks { display: grid; gap: 0.7rem; margin-top: 1.8rem; }
    .vchecks li { display: flex; gap: 0.85rem; align-items: flex-start; color: var(--ink-soft); line-height: 1.5; font-size: 1.05rem; }
    .vcheck { flex: 0 0 auto; width: 28px; height: 28px; border-radius: 50%; display: grid; place-items: center; background: var(--green-050); color: var(--green-600); }
    .vcheck svg { width: 15px; height: 15px; }

    /* benefícios */
    .vbenes { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; margin-top: 2rem; }
    .vbenes li { display: flex; gap: 0.8rem; align-items: flex-start; background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 1.1rem 1.2rem; color: var(--ink-soft); line-height: 1.45; }
    .vbene__i { font-size: 1.35rem; line-height: 1; }
    @media (max-width: 640px) { .vbenes { grid-template-columns: 1fr; } }

    /* prova */
    .vprova { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: clamp(1.2rem, 3vw, 2rem); align-items: center; margin-top: 2rem; }
    .vprova__media { position: relative; aspect-ratio: 9/16; border-radius: 16px; overflow: hidden; background: #06170f; display: grid; place-items: center; }
    .vprova__video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .vprova__play { position: relative; z-index: 1; width: 60px; height: 60px; border-radius: 50%; background: rgba(255,255,255,.94); color: var(--green-800); display: grid; place-items: center; padding-left: 3px; }
    .vprova__stat { display: block; font-size: clamp(1.9rem, 1.4rem + 2vw, 2.8rem); font-weight: 800; letter-spacing: -0.03em; color: #fff; }
    .vprova__statl { display: block; color: #9fe0bf; font-weight: 600; margin-top: 0.2rem; }
    .vprova__q { margin: 1.3rem 0 0.7rem; font-size: 1.12rem; line-height: 1.5; color: #eaf1ec; }
    .vprova__quem { color: #b9c6bf; font-size: 0.95rem; }
    .vprova__quem strong { color: #fff; }
    .vprova__logos { text-align: center; margin-top: 2rem; color: #7fa090; font-size: 0.9rem; }
    @media (max-width: 620px) { .vprova { grid-template-columns: 1fr; } .vprova__media { max-width: 240px; margin-inline: auto; } }

    /* oferta */
    .voferta { display: grid; gap: 0.7rem; margin-top: 1.8rem; }
    .voferta li { display: flex; gap: 0.85rem; align-items: flex-start; background: #fff; border: 1px solid var(--line); border-radius: 12px; padding: 1.05rem 1.2rem; color: var(--ink-soft); line-height: 1.5; }
    .voferta__i { font-size: 1.2rem; line-height: 1.2; }

    /* garantias */
    .vgar { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    .vgar li { background: var(--paper); border: 1px solid var(--line); border-radius: 14px; padding: 1.4rem; }
    .vgar__i { font-size: 1.6rem; }
    .vgar h3 { margin: 0.6rem 0 0.4rem; font-size: 1.1rem; }
    .vgar p { color: var(--ink-soft); font-size: 0.96rem; line-height: 1.5; }
    @media (max-width: 720px) { .vgar { grid-template-columns: 1fr; } }

    /* faq */
    .vfaq { display: grid; gap: 0.6rem; margin-top: 2rem; }
    .vfaq__item { background: #fff; border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
    .vfaq__q { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1rem; text-align: left; padding: 1.1rem 1.3rem; font-weight: 700; color: var(--ink); font-size: 1.02rem; }
    .vfaq__q svg { flex: 0 0 auto; width: 20px; height: 20px; color: var(--green-600); transition: transform .3s; }
    .vfaq__item.is-open .vfaq__v { opacity: 0; }
    .vfaq__a { max-height: 0; overflow: hidden; transition: max-height .35s var(--ease); }
    .vfaq__a p { padding: 0 1.3rem 1.2rem; color: var(--ink-soft); line-height: 1.6; }

    /* fechamento */
    .vclose .vcta { margin-top: 2.2rem; }
    .vps { margin-top: 2.2rem; padding-top: 1.6rem; border-top: 1px solid rgba(255,255,255,.12); color: #b9c6bf; line-height: 1.6; font-size: 0.98rem; }
    .vps strong { color: #fff; }

    /* footer */
    .vft { background: var(--ink); color: #c8cdc6; padding-block: 1.8rem; }
    .vft__in { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; font-size: 0.85rem; }
    .vft a { color: #9fe0bf; font-weight: 600; }

    /* sticky mobile CTA */
    .vsticky { display: none; position: fixed; left: 12px; right: 12px; bottom: 12px; z-index: 90; text-align: center; background: #1e7a56; color: #fff; font-weight: 800; padding: 1em; border-radius: 12px; box-shadow: 0 12px 30px -8px rgba(0,0,0,.45); }
    @media (max-width: 720px) { .vsticky { display: block; } .vhd__cta { display: none; } }
  </style>
</LightLayout>
