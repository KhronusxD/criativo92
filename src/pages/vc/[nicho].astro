---
import LpSales from '../../components/LpSales.astro';
import { lpVB } from '../../data/lp-vb.js';

export function getStaticPaths() {
  return Object.keys(lpVB).map((slug) => ({ params: { nicho: slug }, props: { d: lpVB[slug] } }));
}
const { d } = Astro.props;
---
<LpSales d={d} variant="C" />
